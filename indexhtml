<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ApexVolt Motors</title>
  <meta name="description" content="ApexVolt Motors — electric off-road motorcycles. Neon Series." />
  <style>
    :root{
      --bg:#050505;
      --panel:#101010;
      --panel2:#151515;
      --text:#f5f5f5;
      --muted:#a8a8a8;
      --neon:#b7ff2d;
      --line:rgba(183,255,45,.18);
    }

    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:Arial,Helvetica,sans-serif;
      background:
        radial-gradient(circle at top right, rgba(183,255,45,.12), transparent 22%),
        linear-gradient(180deg,#080808 0%,#050505 100%);
      color:var(--text);
    }

    a{text-decoration:none;color:inherit}

    .wrap{
      width:min(1180px,calc(100% - 24px));
      margin:0 auto;
    }

    .nav{
      position:sticky;
      top:0;
      z-index:50;
      background:rgba(5,5,5,.82);
      backdrop-filter:blur(10px);
      border-bottom:1px solid rgba(255,255,255,.06);
    }

    .nav-inner{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      padding:14px 0;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      font-weight:900;
      letter-spacing:.05em;
    }

    .brand img{
      width:42px;
      height:42px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.08);
    }

    .cta{
      background:linear-gradient(135deg,var(--neon),#86ff00);
      color:#071100;
      padding:12px 16px;
      border-radius:999px;
      font-weight:900;
    }

    .hero{
      padding:56px 0 28px;
    }

    .hero-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:24px;
      align-items:center;
    }

    .eyebrow{
      color:var(--neon);
      font-weight:800;
      letter-spacing:.14em;
      text-transform:uppercase;
      font-size:.78rem;
      margin-bottom:16px;
    }

    h1{
      margin:0 0 16px;
      font-size:clamp(2.6rem,9vw,5.6rem);
      line-height:.95;
      letter-spacing:-.05em;
    }

    h1 span{
      color:var(--neon);
    }

    .lead{
      color:var(--muted);
      font-size:1.04rem;
      line-height:1.7;
      margin-bottom:22px;
    }

    .buttons{
      display:flex;
      flex-wrap:wrap;
      gap:12px;
      margin-bottom:22px;
    }

    .btn{
      padding:14px 18px;
      border-radius:14px;
      font-weight:800;
      border:1px solid rgba(255,255,255,.08);
      background:#111;
    }

    .btn.primary{
      background:linear-gradient(135deg,var(--neon),#86ff00);
      color:#071100;
      border:none;
    }

    .hero-card{
      background:linear-gradient(180deg,rgba(255,255,255,.03),rgba(255,255,255,.015));
      border:1px solid rgba(255,255,255,.06);
      border-radius:28px;
      overflow:hidden;
      position:relative;
    }

    .hero-card img{
      width:100%;
      display:block;
    }

    .badge{
      position:absolute;
      top:16px;
      left:16px;
      padding:10px 14px;
      border-radius:999px;
      background:rgba(0,0,0,.55);
      color:var(--neon);
      border:1px solid var(--line);
      font-weight:800;
      font-size:.9rem;
    }

    .section{
      padding:18px 0 30px;
    }

    .section h2{
      margin:0 0 10px;
      font-size:clamp(1.8rem,5vw,3rem);
      letter-spacing:-.04em;
    }

    .section p{
      color:var(--muted);
      line-height:1.7;
    }

    .grid-2{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:20px;
    }

    .card{
      background:var(--panel);
      border:1px solid rgba(255,255,255,.06);
      border-radius:24px;
      padding:22px;
    }

    .specs{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
      margin-top:16px;
    }

    .spec{
      background:var(--panel2);
      border:1px solid rgba(255,255,255,.06);
      border-radius:16px;
      padding:14px;
    }

    .spec small{
      display:block;
      color:var(--muted);
      margin-bottom:6px;
      text-transform:uppercase;
      font-size:.75rem;
      letter-spacing:.08em;
    }

    .spec strong{
      font-size:1rem;
    }

    .lineup img{
      width:100%;
      border-radius:24px;
      border:1px solid rgba(255,255,255,.06);
    }

    .colors{
      display:grid;
      grid-template-columns:repeat(6,1fr);
      gap:12px;
      margin-top:18px;
    }

    .color{
      background:var(--panel);
      border:1px solid rgba(255,255,255,.06);
      border-radius:18px;
      padding:14px;
      text-align:center;
    }

    .dot{
      width:52px;
      height:52px;
      border-radius:50%;
      margin:0 auto 10px;
      border:2px solid rgba(255,255,255,.15);
    }

    .contact{
      display:grid;
      grid-template-columns:1fr .9fr;
      gap:20px;
      align-items:stretch;
    }

    .qr{
      text-align:center;
    }

    .qr img{
      width:min(260px,100%);
      margin:0 auto 12px;
      background:#fff;
      border-radius:18px;
      padding:10px;
    }

    footer{
      padding:24px 0 90px;
      color:var(--muted);
      text-align:center;
      border-top:1px solid rgba(255,255,255,.06);
      margin-top:18px;
    }

    .mobile-bar{
      position:fixed;
      left:12px;
      right:12px;
      bottom:12px;
      display:none;
      gap:10px;
      padding:10px;
      border-radius:20px;
      background:rgba(10,10,10,.9);
      border:1px solid rgba(255,255,255,.08);
      backdrop-filter:blur(10px);
    }

    .mobile-bar a{
      flex:1;
      text-align:center;
      padding:12px;
      border-radius:14px;
      font-weight:800;
    }

    .mobile-bar a:first-child{
      background:linear-gradient(135deg,var(--neon),#86ff00);
      color:#071100;
    }

    .mobile-bar a:last-child{
      background:#151515;
      color:#fff;
      border:1px solid rgba(255,255,255,.08);
    }

    @media (max-width: 900px){
      .hero-grid,.grid-2,.contact{
        grid-template-columns:1fr;
      }
      .colors{
        grid-template-columns:repeat(3,1fr);
      }
    }

    @media (max-width: 640px){
      .colors{
        grid-template-columns:repeat(2,1fr);
      }
      .specs{
        grid-template-columns:1fr 1fr;
      }
      .mobile-bar{
        display:flex;
      }
      footer{
        padding-bottom:100px;
      }
    }
  </style>
</head>
